# ══════════════════════════════════════════════════════════
# Lead Qualifier — Docker Environment Variables
# Copy this to .env.docker and fill in your values
# ══════════════════════════════════════════════════════════

# ── Required: LinkedIn Authentication ──
# JSON array of accounts: [{"email":"you@gmail.com","password":"yourpass"}]
LINKEDIN_ACCOUNTS=[{"email":"your_email","password":"your_password"}]

# ── Required: LinkedIn Session Cookie ──
LINKEDIN_LI_AT=your_li_at_cookie_here

# ── Optional: Google Sheets Export ──
GOOGLE_SHEETS_CREDENTIALS_BASE64=
GOOGLE_SHEETS_SPREADSHEET_ID=

# ── Puppeteer (auto-configured in Docker) ──
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
