# ──────────────────────────────────────────────────
# Revlane Signal Engine — Environment Variables
# Copy this file to .env.local and fill in your values
# ──────────────────────────────────────────────────

# ── Required: Bright Data API ──
BRIGHT_DATA_API_KEY=your_bright_data_api_key_here

# ── Required: Bright Data Dataset IDs ──
BD_DATASET_ACTIVITY=gd_lyy3tktm25m4avu764
BD_DATASET_PROFILES=gd_l1viktl72bvl7bjuj0
BD_DATASET_WEB_SCRAPER=gd_m6gjtfmeh43we6cqc

# ── Required: LinkedIn Authentication ──
# Get this from browser DevTools → Application → Cookies → linkedin.com → li_at
LINKEDIN_LI_AT=your_linkedin_li_at_cookie_here

# ── Optional: Bright Data Residential Proxy ──
BD_PROXY_URL=http://brd-customer-CUSTOMER_ID-zone-ZONE:PASSWORD@brd.superproxy.io:33335

# ── Optional: Google Sheets Export ──
# Service account credentials JSON (base64 encoded)
# 1. Create a service account at https://console.cloud.google.com
# 2. Enable the Google Sheets API
# 3. Download the JSON key file
# 4. Base64 encode it: base64 -w0 credentials.json
# 5. Paste the result below
GOOGLE_SHEETS_CREDENTIALS_BASE64=

# Optional: Default spreadsheet ID to append to (leave empty to create new)
GOOGLE_SHEETS_SPREADSHEET_ID=
